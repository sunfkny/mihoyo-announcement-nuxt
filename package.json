{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "eslint --fix",
    "lint": "eslint ."
  },
  "dependencies": {
    "@nuxt/ui": "^4.5.1",
    "@vueuse/core": "^14.2.1",
    "clsx": "^2.1.1",
    "happy-dom": "^20.8.4",
    "nuxt": "^4.4.2",
    "ofetch": "^1.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "ufo": "^1.6.1",
    "valibot": "^1.2.0",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@iconify-json/lucide": "^1.2.96",
    "@nuxt/eslint": "^1.12.1",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.8"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:vite@8.0.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite": "*",
        "eslint": "*",
        "vue-router": "*"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
