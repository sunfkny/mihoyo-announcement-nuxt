  },
  "dependencies": {
    "@nuxt/ui": "^4.7.0",
    "@vueuse/core": "^14.2.1",
    "clsx": "^2.1.1",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.4.2",
    "ofetch": "^1.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "ufo": "^1.6.3",
    "valibot": "^1.3.1",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@iconify-json/lucide": "^1.2.104",
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
